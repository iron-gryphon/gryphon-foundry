# =============================================================================
# gryphon-foundry: terraform.tfvars.example
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values:
#   cp terraform.tfvars.example terraform.tfvars
#
# SECURITY: terraform.tfvars is gitignored. Never commit credentials.
# AWS credentials are NOT set here - use environment variables or ~/.aws/credentials.
# See SETUP.md for credential and endpoint configuration.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
environment = "sandbox"

# -----------------------------------------------------------------------------
# AWS Region & Availability Zones
# -----------------------------------------------------------------------------
aws_region = "us-east-2"

availability_zones = [
  "us-east-2a",
  "us-east-2b",
  "us-east-2c"
]

# -----------------------------------------------------------------------------
# Nest VPC (Connected - for oc-mirror, datasets, Terraform providers)
# -----------------------------------------------------------------------------
nest_vpc_cidr = "10.0.0.0/16"

nest_public_subnet_cidrs = [
  "10.0.1.0/24",
  "10.0.2.0/24",
  "10.0.3.0/24"
]

# -----------------------------------------------------------------------------
# Vault VPC (Isolated - air-gapped for OCP/RHOAI)
# -----------------------------------------------------------------------------
vault_vpc_cidr = "10.1.0.0/16"

vault_private_subnet_cidrs = [
  "10.1.1.0/24",
  "10.1.2.0/24",
  "10.1.3.0/24"
]

# -----------------------------------------------------------------------------
# Optional: Tags
# -----------------------------------------------------------------------------
tags = {
  Team        = "iron-gryphon"
  CostCenter  = "fsi-ai"
}

# -----------------------------------------------------------------------------
# Route53 Hosted Zone (from Red Hat Demo Platform sandbox)
# -----------------------------------------------------------------------------
# The sandbox provides a hosted zone name - use it for bastion DNS (bastion.<zone>).
# Leave empty ("") to skip Route53 record creation.
route53_hosted_zone_name = "your-sandbox-hosted-zone.example.com"

# -----------------------------------------------------------------------------
# OCP Base Domain (must match gryphon-forge base_domain)
# -----------------------------------------------------------------------------
# create_ocp_private_zone (terraform output) is true when: ocp_base_domain is set and
# either route53_hosted_zone_name is empty or the two differ (e.g. sandbox zone +
# fsi.internal). Then outputs internal_hosted_zone_id is the new private zone.
# If ocp_base_domain is empty, effective domain is route53_hosted_zone_name (existing zone).
# If ocp_base_domain equals route53_hosted_zone_name, the existing zone is used (private zone not created).
# gryphon-forge creates api, api-int, *.apps in that zone after NLBs exist—not Terraform.
# ocp_base_domain = "fsi.internal"
#
# When reusing an existing *private* zone (same name as route53_hosted_zone_name), Foundry
# associates it with the Vault VPC by default. Set false only if you use Resolver forwarding:
# associate_existing_ocp_route53_zone_with_vault_vpc = false

# -----------------------------------------------------------------------------
# Optional: OCP cluster name (used for API URL; cluster sizing is in the UPI project)
# -----------------------------------------------------------------------------
ocp_cluster_name = "gryphon-ocp"

# -----------------------------------------------------------------------------
# Optional: ACM certificate for OpenShift ingress (*.apps.<cluster>.<domain>)
# -----------------------------------------------------------------------------
# When true, creates ACM cert; gryphon-forge uses ALB with HTTPS instead of NLB.
# create_ingress_certificate = true

# For internal domains (e.g. fsi.internal), use Private CA:
# use_ingress_private_ca = true
# ocp_ingress_base_domain = "fsi.internal"

# For public Route53 zones (e.g. sandbox), use public ACM with DNS validation:
# use_ingress_private_ca = false
# (route53_hosted_zone_name must be set)

# -----------------------------------------------------------------------------
# Bastion Host (required - create key pair first: aws ec2 create-key-pair --key-name <name>)
# -----------------------------------------------------------------------------
bastion_key_name = "your-bastion-key-name"

# Root disk for oc-mirror workspace and home-directory setup (default 28 GiB ≈ +20 GiB vs typical AMI)
# bastion_root_volume_gb = 32

# Optional: Restrict SSH to specific IPs for security
# bastion_ssh_allowed_cidrs = ["1.2.3.4/32"]

# OpenShift CLI + oc-mirror on bastion use stable-<ocp_version> unless you override:
# bastion_oc_cli_version = "stable-4.20"

# Where to copy your pull-secret.json on the bastion (default: ~/.openshift/pull-secret)
# oc_mirror_pull_secret_path = "~/.openshift/pull-secret"

# -----------------------------------------------------------------------------
# Mirror registry (disconnected OCP — Nest VPC)
# -----------------------------------------------------------------------------
# When true (default), provisions mirror.<ocp_base_domain> with TLS (SAN) and outputs
# mirror_registry_url + mirror_registry_additional_trust_bundle for gryphon-forge.
# create_mirror_registry = false
# mirror_registry_root_volume_gb = 500
# mirror_registry_tls_extra_san_dns_names = ["registry.example.internal"]
